---
import {
  getPortfolioAccentClass,
  getPortfolioGridClass,
  type PortfolioProject,
} from "./portfolio-data";

interface Props {
  project: PortfolioProject;
  index: number;
}

const { project, index } = Astro.props as Props;

const visualLabel = project.visual.label;
---

<article
  class={`portfolio-card portfolio-card--${
    project.layout.replaceAll(" ", "-")
  } group relative isolate overflow-hidden rounded-4xl border border-skala-border bg-[#181816] shadow-[0_24px_70px_rgba(0,0,0,0.22)] transition duration-300 hover:-translate-y-1 hover:border-skala-accent/35 ${getPortfolioGridClass(
    project,
  )}`}
  data-project-card
  data-category={project.category}
  data-reveal
  data-reveal-variant={index % 3}
  style={`--reveal-delay: ${Math.min(index * 42, 360)}ms;`}
>
  <div
    class="relative block aspect-16/10 overflow-hidden bg-skala-surface"
    aria-hidden="true"
  >
    <div
      class="absolute inset-0 transition duration-500 group-hover:scale-105"
      style={`background: ${project.visual.gradient};`}
    >
    </div>

    <div
      class="absolute inset-0 bg-[linear-gradient(180deg,transparent_40%,rgba(8,8,8,0.72)_100%)] opacity-70"
    >
    </div>

    <div class="absolute inset-x-0 bottom-0 p-5 sm:p-6 lg:p-8">
      <span class={`mb-3 inline-flex h-2 w-10 rounded-full ${getPortfolioAccentClass(project)}`}></span>
      <p
        class="m-0 text-[0.68rem] font-black uppercase tracking-[0.22em] text-skala-accent"
      >
        {project.categoryLabel}
      </p>
      <h3
        class="mt-3 max-w-[18ch] font-display text-2xl font-black leading-tight tracking-[-0.04em] text-skala-text md:text-3xl"
      >
        {project.title}
      </h3>
    </div>

    <span
      class="portfolio-badge absolute right-5 top-5 inline-flex rounded-full border border-white/10 bg-white/8 px-3 py-1.5 text-xs font-bold uppercase tracking-[0.14em] text-skala-muted opacity-0 transition duration-300 group-hover:-translate-y-0.5 group-hover:opacity-100"
    >
      {visualLabel}
    </span>
  </div>

  <div
    class="flex items-center justify-between gap-4 border-t border-white/8 p-4 sm:p-5"
  >
    <span class="min-w-0 text-sm text-skala-muted">
      {project.title} · {project.client}
    </span>
    <span class={`h-2 w-2 shrink-0 rounded-full ${getPortfolioAccentClass(project)}`}></span>
  </div>

  <a
    href={`#${project.id}`}
    class="portfolio-overlay absolute inset-0 z-10 flex flex-col justify-end bg-[rgba(8,8,8,0.9)] p-5 opacity-0 transition duration-300 focus-visible:ring-2 focus-visible:ring-skala-accent/70 group-hover:opacity-100 sm:p-6 lg:p-8"
    aria-label={`Abrir caso: ${project.title}`}
  >
    <p
      class="mb-3 text-[0.68rem] font-black uppercase tracking-[0.22em] text-skala-accent"
    >
      {project.categoryLabel}
    </p>
    <h3
      class="mb-2 font-display text-2xl font-black leading-tight tracking-[-0.04em] text-skala-text md:text-3xl"
    >
      {project.title}
    </h3>
    <p class="mb-6 text-sm text-skala-muted">Cliente: {project.client}</p>
    <span
      class="inline-flex w-fit items-center gap-2 text-[0.72rem] font-black uppercase tracking-[0.14em] text-skala-accent"
    >
      {project.overlay}
      <span aria-hidden="true">→</span>
    </span>
  </a>
</article>

<style>
  .portfolio-card {
    animation: portfolioFadeIn 0.52s ease both;
    transform-origin: center;
  }

  .portfolio-card[data-reveal-variant="1"] {
    animation-name: portfolioFadeInLeft;
  }

  .portfolio-card[data-reveal-variant="2"] {
    animation-name: portfolioFadeInRight;
  }

  .portfolio-card--full,
  .portfolio-card--narrow-tall {
    animation-duration: 0.62s;
  }

  .portfolio-card--full {
    animation-name: portfolioFadeInWide;
  }

  .portfolio-card--narrow-tall {
    animation-name: portfolioFadeInTall;
  }

  .portfolio-badge {
    backdrop-filter: blur(12px);
  }

  @media (prefers-reduced-motion: reduce) {
    .portfolio-card,
    .portfolio-card > *,
    .portfolio-overlay,
    .portfolio-badge {
      animation: none !important;
      transition-duration: 0.01ms !important;
    }
  }

  @keyframes portfolioFadeIn {
    from {
      opacity: 0;
      transform: translate3d(0, 22px, 0) scale(0.985);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0) scale(1);
    }
  }

  @keyframes portfolioFadeInLeft {
    from {
      opacity: 0;
      transform: translate3d(-24px, 20px, 0) scale(0.985);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0) scale(1);
    }
  }

  @keyframes portfolioFadeInRight {
    from {
      opacity: 0;
      transform: translate3d(24px, 20px, 0) scale(0.985);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0) scale(1);
    }
  }

  @keyframes portfolioFadeInWide {
    from {
      opacity: 0;
      transform: translate3d(0, 28px, 0) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0) scale(1);
    }
  }

  @keyframes portfolioFadeInTall {
    from {
      opacity: 0;
      transform: translate3d(0, 26px, 0) scaleY(0.965);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0) scaleY(1);
    }
  }
</style>
