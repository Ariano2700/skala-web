---
import {
  countMedia,
  getCoverMedia,
  getPortfolioAccentStyle,
  getPortfolioGridClass,
  type PortfolioProjectItem,
} from "../../data/portafolio";

interface Props {
  project: PortfolioProjectItem;
  index: number;
}

const { project, index } = Astro.props as Props;

const cover = getCoverMedia(project);
const mediaCount = countMedia(project);
const hasMultiple = project.media.length > 1;
---

<button
  type="button"
  class={`cursor-pointer portfolio-card portfolio-card--${project.layout.replaceAll(" ", "-")} group relative isolate block w-full overflow-hidden rounded-4xl border border-skala-border bg-[#181816] text-left shadow-[0_24px_70px_rgba(0,0,0,0.22)] transition duration-300 ${getPortfolioGridClass(project)}`}
  data-project-card
  data-category={project.categories.join(" ")}
  data-project-id={project.id}
  data-project={JSON.stringify(project)}
  data-open-project
  data-reveal
  data-reveal-variant={index % 3}
  style={`--reveal-delay: ${Math.min(index * 42, 360)}ms;`}
  aria-label={`Ver proyecto: ${project.title}`}
>
  <div class="relative aspect-square overflow-hidden bg-skala-surface">
    {
      cover.type === "image" ? (
        <img
          src={cover.src}
          alt={cover.alt ?? project.title}
          loading="lazy"
          class="portfolio-image-container absolute inset-0 h-full w-full object-cover transition duration-700"
        />
      ) : (
        <video
          src={cover.src}
          muted
          loop
          playsinline
          preload="metadata"
          class="portfolio-image-container absolute inset-0 h-full w-full object-cover transition duration-700"
        />
      )
    }

    <div
      class="portfolio-gradient-overlay absolute inset-0 bg-[linear-gradient(180deg,rgba(8,8,8,0.08)_0%,rgba(8,8,8,0.36)_46%,rgba(8,8,8,0.86)_100%)] opacity-90 transition-opacity duration-300"
    >
    </div>

    <div
      class="portfolio-shine absolute -inset-x-8 -top-2 h-16 w-20 -rotate-45 bg-linear-to-r from-transparent via-white/10 to-transparent opacity-0 transition-opacity duration-500"
    >
    </div>

    <div class="absolute inset-x-0 bottom-0 p-5 sm:p-6 lg:p-8">
      <span
        class="mb-3 inline-flex h-2 w-10 rounded-full"
        style={getPortfolioAccentStyle(project)}
      ></span>
      <p
        class="m-0 text-[0.68rem] font-black uppercase tracking-[0.22em] text-skala-accent"
      >
        {project.categoryLabel}
      </p>
      <h3
        class="mt-3 max-w-[18ch] font-display text-2xl font-black leading-tight tracking-[-0.04em] text-skala-text md:text-3xl"
      >
        {project.title}
      </h3>
    </div>

    {
      hasMultiple && (
        <span class="portfolio-badge absolute right-5 top-5 inline-flex items-center gap-1.5 rounded-full border border-white/10 bg-white/8 px-3 py-1.5 text-xs font-bold uppercase tracking-[0.14em] text-skala-muted opacity-0 transition duration-300">
          {mediaCount.images > 0 && <span>{mediaCount.images} img</span>}
          {mediaCount.images > 0 && mediaCount.videos > 0 && <span>·</span>}
          {mediaCount.videos > 0 && <span>{mediaCount.videos} vid</span>}
        </span>
      )
    }
  </div>

  <div
    class="flex items-center justify-between gap-4 border-t border-white/8 p-4 sm:p-5"
  >
    <span class="min-w-0 text-sm text-skala-muted">
      {project.title} · {project.client}
    </span>
    <span
      class="h-2 w-2 shrink-0 rounded-full"
      style={getPortfolioAccentStyle(project)}
    ></span>
  </div>

  <div
    class="portfolio-overlay absolute inset-0 z-10 flex flex-col justify-end bg-[rgba(8,8,8,0.9)] p-5 opacity-0 transition duration-300 focus-visible:ring-2 focus-visible:ring-skala-accent/70 sm:p-6 lg:p-8"
  >
    <p
      class="mb-3 text-[0.68rem] font-black uppercase tracking-[0.22em] text-skala-accent"
    >
      {project.categoryLabel}
    </p>
    <h3
      class="mb-2 font-display text-2xl font-black leading-tight tracking-[-0.04em] text-skala-text md:text-3xl"
    >
      {project.title}
    </h3>
    <p class="mb-6 text-sm text-skala-muted">Cliente: {project.client}</p>
    <span
      class="inline-flex w-fit items-center gap-2 text-[0.72rem] font-black uppercase tracking-[0.14em] text-skala-accent"
    >
      {project.overlay}
      <span aria-hidden="true">→</span>
    </span>
  </div>
</button>
