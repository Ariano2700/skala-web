---
import {
  //portfolioProjects,
  type PortfolioProjectItem,
  type PortfolioCategoryValue,
} from "../../data/portafolio";
import { getAllCategoriesByOrder } from "../../sanity/category/api";

interface Props {
  projects?: PortfolioProjectItem[];
}

const { projects = [] } = Astro.props;

// Categorías 100% dinámicas desde Sanity (CMS). El filtro usa el slug real
// de cada categoría. Si el CMS no responde, se usa el conjunto de slugs
// presentes en los proyectos estáticos como respaldo.
const sanityCategories = await getAllCategoriesByOrder();
// const fallbackCategories = Array.from(
//   new Set(projects.flatMap((p) => p.categories)),
// ).map((slug) => ({ title: slug, slug, accent: undefined }));

const rawCategories =
  sanityCategories.length > 0
    ? sanityCategories
    : projects.flatMap((p) =>
        p.categories.map((slug) => ({
          title: slug,
          slug,
          accent: undefined,
        })),
      );

// Filtro activo leído desde el query param ?categoria= (default "all").
const activeParam = Astro.url.searchParams.get("categoria") ?? "all";
const activeFilter: PortfolioCategoryValue =
  activeParam === "all" || rawCategories.some((c) => c.slug === activeParam)
    ? (activeParam as PortfolioCategoryValue)
    : "all";

const filters: {
  label: string;
  value: PortfolioCategoryValue;
  accent?: string;
}[] = [
  { label: "Todos", value: "all" },
  ...rawCategories.map((cat) => ({
    label: cat.title,
    value: cat.slug,
    accent: cat.accent,
  })),
];
---

<div
  class="portfolio-filters sticky top-18 z-40 border-y border-skala-border bg-[#04142e]/94 py-4 backdrop-blur-xl"
  aria-label="Filtros de portafolio"
>
  <div
    class="mx-auto flex max-w-360 flex-wrap items-center gap-3 px-5 md:px-12"
  >
    {
      filters.map((filter) => {
        const isActive = filter.value === activeFilter;
        // Color de acento dinámico (hex de Sanity) o el del tema por defecto.
        const accentVar = filter.accent
          ? `--filter-accent: ${filter.accent};`
          : "";
        return (
          <a
            href={`?categoria=${filter.value}`}
            title={`Filtrar por ${filter.label}`}
            aria-label={`Filtrar por ${filter.label}`}
            class={`cursor-pointer portfolio-filter group rounded-full border px-4 py-2.5 text-[0.7rem] font-black uppercase tracking-[0.14em] transition duration-200 focus-visible:ring-2 focus-visible:ring-skala-accent/60 ${
              isActive ? "is-active" : ""
            }`}
            style={accentVar}
            data-filter={filter.value}
            aria-pressed={isActive ? "true" : "false"}
          >
            {filter.label}
          </a>
        );
      })
    }

    <span
      class="ml-auto text-xs font-medium uppercase tracking-[0.16em] text-skala-muted"
      data-filter-count
    >
      {`${projects.length} proyectos`}
    </span>
  </div>
</div>
