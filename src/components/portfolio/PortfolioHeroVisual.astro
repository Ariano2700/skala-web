---

---

<div
  class="portfolio-hero-visual pointer-events-none relative inset-x-0 top-0 z-0 h-80 lg:h-96"
  data-portfolio-hero-parallax
  aria-hidden="true"
>
  <div
    class="portfolio-hero-glow absolute left-1/2 h-72 w-72 -translate-x-1/2 -translate-y-1/2 rounded-full bg-skala-accent/10 blur-3xl"
  >
  </div>

  <div
    class="portfolio-parallax-card portfolio-card-reel absolute right-0 md:left-24 top-8 z-30 h-58 w-42 overflow-hidden rounded-[1.75rem] border border-white/10 bg-[#101827] shadow-[0_30px_80px_rgba(0,0,0,0.42)]"
    data-parallax-card
    data-depth="18"
    style="--rz: -7deg; --z: 34px;"
  >
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(92,216,252,0.32),transparent_34%),linear-gradient(145deg,#18243a_0%,#08101f_55%,#111827_100%)]"
    >
    </div>
    <div class="absolute inset-x-4 top-4 flex items-center justify-between">
      <span class="h-2 w-16 rounded-full bg-white/20"></span>
      <span
        class="rounded-full border border-white/12 bg-white/10 px-2 py-1 text-[0.56rem] font-black uppercase tracking-[0.14em] text-white/70"
      >
        Reel
      </span>
    </div>
    <div class="absolute inset-x-5 bottom-16">
      <p class="text-xs font-black uppercase tracking-[0.2em] text-white/55">
        Showreel
      </p>
      <p
        class="mt-2 font-display text-2xl font-black leading-none tracking-tighter text-white"
      >
        Motion<br />
        Brand
      </p>
    </div>
    <div class="absolute bottom-5 left-5 right-5 h-1 rounded-full bg-white/12">
      <span class="block h-full w-2/3 rounded-full bg-skala-accent"></span>
    </div>
    <div
      class="absolute bottom-12 left-1/2 flex h-14 w-14 -translate-x-1/2 items-center justify-center rounded-full bg-skala-accent shadow-[0_0_40px_rgba(92,216,252,0.34)]"
    >
      <span
        class="ml-1 h-0 w-0 border-y-4 border-y-transparent border-l-7 border-l-[#04142e] border-l-solid"
      ></span>
    </div>
  </div>

  <div
    class="portfolio-parallax-card portfolio-card-brand absolute md:right-20 top-2 z-20 h-40 w-34 overflow-hidden rounded-[1.35rem] border border-white/10 bg-[#f4efe6] shadow-[0_24px_64px_rgba(0,0,0,0.36)]"
    data-parallax-card
    data-depth="12"
    style="--rz: 10deg; --z: 18px;"
  >
    <div
      class="absolute inset-0 bg-[linear-gradient(135deg,rgba(244,239,230,1),rgba(219,207,185,0.92))]"
    >
    </div>
    <div
      class="absolute inset-4 rounded-[0.8rem] border border-[#1c1712]/12 bg-white/45 p-3"
    >
      <div class="flex items-center justify-between">
        <span
          class="font-display text-sm font-black tracking-[-0.06em] text-[#1c1712]"
        >
          SK
        </span>
        <span class="h-2 w-8 rounded-full bg-[#c8f135]"></span>
      </div>
      <div class="mt-5 h-14 rounded-[0.65rem] bg-[#1c1712]"></div>
      <div class="mt-3 grid grid-cols-3 gap-1.5">
        <span class="h-6 rounded bg-[#c8f135]"></span>
        <span class="h-6 rounded bg-[#1c1712]"></span>
        <span class="h-6 rounded bg-[#f05a28]"></span>
      </div>
      <p
        class="mt-4 text-[0.5rem] font-black uppercase tracking-[0.18em] text-[#1c1712]/55"
      >
        Identity
      </p>
    </div>
  </div>

  <div
    class="portfolio-parallax-card portfolio-card-social absolute bottom-8 top-50 right-28 md:right-1/3 z-40 h-32 w-44 overflow-hidden rounded-[1.35rem] border border-skala-accent/20 bg-[rgba(8,24,52,0.88)] shadow-[0_24px_70px_rgba(0,22,52,0.38)]"
    data-parallax-card
    data-depth="24"
    style="--rz: -2deg; --z: 48px;"
  >
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_80%_10%,rgba(92,216,252,0.22),transparent_38%)]"
    >
    </div>
    <div class="relative p-4">
      <div class="flex items-center justify-between">
        <span
          class="text-[0.55rem] font-black uppercase tracking-[0.16em] text-skala-muted"
        >
          Social
        </span>
        <span
          class="rounded-full bg-skala-accent/12 px-2 py-1 text-[0.5rem] font-black text-skala-accent"
        >
          +42%
        </span>
      </div>
      <div class="mt-4 space-y-2">
        <span class="block h-2 rounded-full bg-white/10"></span>
        <span class="block h-2 w-4/5 rounded-full bg-skala-accent/55"></span>
        <span class="block h-2 w-3/5 rounded-full bg-white/10"></span>
      </div>
      <div class="mt-4 flex gap-2">
        <span class="h-7 flex-1 rounded-lg bg-skala-accent/14"></span>
        <span class="h-7 flex-1 rounded-lg bg-white/8"></span>
        <span class="h-7 flex-1 rounded-lg bg-skala-accent/22"></span>
      </div>
    </div>
  </div>
</div>

<script>
  (() => {
    const root = document.querySelector<HTMLElement>(
      "[data-portfolio-hero-parallax]",
    );
    const cards = root?.querySelectorAll<HTMLElement>("[data-parallax-card]");

    if (!root || !cards?.length) return;

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    const coarsePointer = window.matchMedia("(pointer: coarse)");

    if (reduceMotion.matches || coarsePointer.matches) return;

    let rafId = 0;
    let mouseX = 0;
    let mouseY = 0;
    let rect = root.getBoundingClientRect();

    const updateRect = () => {
      rect = root.getBoundingClientRect();
    };

    const applyMotion = () => {
      rafId = 0;

      const centerX = rect.left + rect.width / 2;
      const centerY = rect.top + rect.height / 2;
      const deltaX = (mouseX - centerX) / rect.width;
      const deltaY = (mouseY - centerY) / rect.height;

      cards.forEach((card) => {
        const depth = Number(card.dataset.depth ?? 12);
        const rotateZ = card.style.getPropertyValue("--rz");
        const translateZ = card.style.getPropertyValue("--z");
        const x = deltaX * depth;
        const y = deltaY * depth;
        const rotateY = deltaX * 8;
        const rotateX = -deltaY * 8;

        card.style.transform = `translate3d(${x.toFixed(2)}px, ${y.toFixed(
          2,
        )}px, 0) rotateX(${rotateX.toFixed(2)}deg) rotateY(${rotateY.toFixed(
          2,
        )}deg) rotateZ(${rotateZ}) translateZ(${translateZ})`;
      });
    };

    const scheduleMotion = (event: PointerEvent) => {
      mouseX = event.clientX;
      mouseY = event.clientY;

      if (!rafId) {
        rafId = requestAnimationFrame(applyMotion);
      }
    };

    root.addEventListener("pointerenter", updateRect, { passive: true });
    root.addEventListener("pointermove", scheduleMotion, { passive: true });
    root.addEventListener(
      "pointerleave",
      () => {
        mouseX = rect.left + rect.width / 2;
        mouseY = rect.top + rect.height / 2;
        scheduleMotion(new PointerEvent("pointermove"));
      },
      { passive: true },
    );

    window.addEventListener("resize", updateRect, { passive: true });
  })();
</script>

<style>
  .portfolio-hero-visual {
    perspective: 900px;
    transform-style: preserve-3d;
  }

  .portfolio-hero-glow {
    transform: translate3d(-50%, -50%, -80px);
  }

  .portfolio-parallax-card {
    transform: translate3d(0, 0, 0) rotateZ(var(--rz)) translateZ(var(--z));
    transition: transform 180ms var(--ease-out);
    transform-style: preserve-3d;
    will-change: transform;
  }

  .portfolio-card-reel {
    animation: portfolioHeroFloatOne 6.5s ease-in-out infinite;
  }

  .portfolio-card-brand {
    animation: portfolioHeroFloatTwo 7.5s ease-in-out infinite;
  }

  .portfolio-card-social {
    animation: portfolioHeroFloatThree 8s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .portfolio-parallax-card {
      animation: none !important;
      transition-duration: 0.01ms !important;
      will-change: auto;
    }
  }

  @keyframes portfolioHeroFloatOne {
    0%,
    100% {
      translate: 0 0;
    }
    50% {
      translate: 0 -10px;
    }
  }

  @keyframes portfolioHeroFloatTwo {
    0%,
    100% {
      translate: 0 0;
    }
    50% {
      translate: 0 8px;
    }
  }

  @keyframes portfolioHeroFloatThree {
    0%,
    100% {
      translate: 0 0;
    }
    50% {
      translate: 0 -7px;
    }
  }
</style>
