---
import { FiMail, FiSend } from "react-icons/fi";
import { CONTACT_DATA } from "../../data/contact_data";
import { FaWhatsapp } from "react-icons/fa";

const portfolioCta = {
  title: "¿Listo para ser el próximo caso?",
  description:
    "Cuéntanos sobre tu marca y armamos una propuesta clara en 24 horas.",
};
---

<section
  id="portfolio-cta"
  class="relative z-10 mx-auto mt-12 w-full max-w-360 px-5 pb-28 md:px-12"
  aria-labelledby="portfolio-cta-title"
>
  <div
    class="overflow-hidden rounded-[28px] border border-skala-border bg-[linear-gradient(135deg,rgba(92,216,252,0.14),rgba(8,24,52,0.96))] p-8 shadow-[0_24px_70px_rgba(0,22,52,0.34)] md:p-12 lg:flex lg:items-center lg:justify-between lg:gap-12"
  >
    <div class="max-w-[62ch]">
      <p
        class="m-0 text-[0.72rem] font-black uppercase tracking-[0.22em] text-skala-accent"
      >
        Nuevo proyecto
      </p>
      <h2
        id="portfolio-cta-title"
        class="mt-4 font-display text-[clamp(2rem,5vw,4.8rem)] font-black leading-[0.95] tracking-[-0.06em] text-skala-text text-wrap:balance"
      >
        {portfolioCta.title}
      </h2>
      <p
        class="mt-5 max-w-[56ch] text-base leading-8 text-skala-muted md:text-lg"
      >
        {portfolioCta.description}
      </p>
    </div>

    <div
      class="mt-8 flex flex-col gap-3 sm:flex-row lg:mt-0 lg:flex-col lg:items-stretch"
    >
      <a
        href={CONTACT_DATA.WHATSAPP_LINK(
          "Hola, quiero cotizar un proyecto de portafolio con Skala.",
        )}
        title="Escribir a WhatsApp"
        aria-label="Escribir a WhatsApp"
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center justify-center gap-3 rounded-full bg-skala-accent px-6 py-4 text-[0.72rem] font-black uppercase tracking-[0.16em] text-skala-text-secondary! transition duration-200 hover:-translate-y-px hover:bg-skala-accent/90 focus-visible:ring-2 focus-visible:ring-skala-accent/60 active:translate-y-px"
      >
        <span class="sr-only">Escribir a WhatsApp</span>
        <FaWhatsapp
          className="h-5 w-5 shrink-0 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
          aria-hidden="true"
        />
        Escribir ahora
      </a>

      <a
        href={`mailto:${CONTACT_DATA.EMAIL_ADDRESS}`}
        target="_blank"
        rel="noopener noreferrer"
        title={`Enviar correo a ${CONTACT_DATA.EMAIL_ADDRESS}`}
        aria-label={`Enviar correo a ${CONTACT_DATA.EMAIL_ADDRESS}`}
        class="group inline-flex items-center justify-center gap-3 rounded-full border border-skala-border bg-white/[0.035] px-6 py-4 text-[0.72rem] font-black uppercase tracking-[0.16em] text-skala-text transition duration-200 hover:-translate-y-px hover:border-skala-accent/35 hover:bg-skala-accent/55 focus-visible:ring-2 focus-visible:ring-skala-accent/60 active:translate-y-px"
      >
        <FiMail
          aria-hidden="true"
          className="size-5"
        />
        Enviar correo
      </a>
    </div>
  </div>
</section>
