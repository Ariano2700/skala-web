---
import { FiArrowUpRight, FiCheckCircle, FiStar, FiCamera, FiVideo, FiBriefcase, FiHeart } from "react-icons/fi";
import SectionLabel from "./SectionLabel.astro";
import { CONTACT_DATA } from "../../data/contact_data";
import { plans, specialServices } from "../../data/plans";

/**
 * Helper: returns true when the plan background is considered "light"
 * so we can adjust check-icon and muted-text colours for readability.
 */
function isLightBg(hex: string): boolean {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return r * 0.299 + g * 0.587 + b * 0.114 > 150;
}
---

<section
  class="mx-auto flex w-full max-w-360 flex-col gap-7 px-5 py-28 md:px-12"
  id="planes"
>
  <SectionLabel label="Nuestros planes" />
  <div class="flex flex-col gap-8 xl:flex-row xl:items-end xl:justify-between">
    <h2
      class="m-0 max-w-[12ch] font-display text-[clamp(2.4rem,4.8vw,5rem)] leading-[0.94] tracking-[-0.065em] text-wrap:balance"
      data-reveal
    >
      Elige el plan que mueve tu marca.
    </h2>
    <p
      class="max-w-[54ch] text-[1.05rem] leading-8 text-skala-muted xl:text-right"
      data-reveal
      style="--reveal-delay: 120ms;"
    >
      O cuéntanos qué necesitas y armamos una propuesta a la medida.
    </p>
  </div>

  <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
    {
      plans.map((plan, index) => {
        const light = isLightBg(plan.colors.bg);
        const mutedColor = light
          ? `${plan.colors.text}b3` /* 70 % opacity */
          : `${plan.colors.text}99`; /* 60 % opacity */
        const checkColor = plan.colors.text;
        const disabledCheck = light
          ? `${plan.colors.text}40`
          : `${plan.colors.text}30`;
        const borderColor = light
          ? `${plan.colors.text}1a`
          : `${plan.colors.text}22`;

        return (
          <article
            class="plan-card group relative flex flex-col gap-5 rounded-[30px] border p-7 shadow-(--shadow) transition duration-300 hover:-translate-y-1.5"
            data-reveal
            style={`
              --plan-bg: ${plan.colors.bg};
              --plan-text: ${plan.colors.text};
              --plan-muted: ${mutedColor};
              --plan-check: ${checkColor};
              --plan-check-disabled: ${disabledCheck};
              --plan-border: ${borderColor};
              --reveal-delay: ${index * 90}ms;
              background-color: var(--plan-bg);
              color: var(--plan-text);
              border-color: var(--plan-border);
            `}
          >
            {plan.featured && (
              <div
                class="absolute -top-3 left-5 inline-flex items-center gap-2 rounded-full px-3 py-2 font-display text-[0.62rem] uppercase tracking-[0.16em] shadow-lg"
                style={`background-color: ${plan.colors.text}; color: ${plan.colors.bg};`}
              >
                <FiStar aria-hidden="true" />
                {plan.badge}
              </div>
            )}

            <h3 class="relative m-0 pt-1 font-display text-[1.05rem] leading-[1.35] tracking-[-0.04em]">
              {plan.name}
            </h3>
            <p class="relative m-0 leading-7" style="color: var(--plan-muted);">
              {plan.tagline}
            </p>

            <div class="flex flex-col gap-1">
              <strong class="font-display text-[1.85rem] tracking-[-0.06em]">
                {plan.price}
              </strong>
              <span
                class="text-[0.66rem] uppercase tracking-[0.18em]"
                style="color: var(--plan-muted);"
              >
                {plan.period}
              </span>
            </div>

            <ul class="m-0 flex list-none flex-col gap-2 p-0">
              {plan.features.map((feature) => (
                <li
                  class:list={[
                    "grid grid-cols-[auto_1fr] items-start gap-2 leading-[1.55]",
                    !feature.included && "opacity-45",
                  ]}
                  style="color: var(--plan-muted);"
                >
                  <FiCheckCircle
                    className={
                      feature.included
                        ? "mt-0.5 h-4.5 w-4.5 shrink-0"
                        : "mt-0.5 h-4.5 w-4.5 shrink-0 opacity-45"
                    }
                    aria-hidden="true"
                  />
                  <span>{feature.label}</span>
                </li>
              ))}
            </ul>

            <a
              href={CONTACT_DATA.WHATSAPP_LINK(plan.cta_link_message)}
              target="_blank"
              rel="noopener noreferrer"
              title={plan.cta}
              aria-label={plan.cta}
              class="plan-cta group mt-auto inline-flex items-center justify-center gap-3 rounded-full border px-6 py-4 font-display text-[0.74rem] font-black uppercase tracking-[0.16em] shadow-lg transition duration-200 hover:-translate-y-0.5 hover:scale-[1.015] focus-visible:ring-2 active:translate-y-px"
              style={`
                background-color: ${plan.colors.text};
                color: ${plan.colors.bg};
                border-color: transparent;
              `}
            >
              <span>{plan.cta}</span>
              <FiArrowUpRight
                aria-hidden="true"
                className="transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
              />
            </a>
          </article>
        );
      })
    }
  </div>

  <!-- Servicios especiales (cotización a medida) -->
  <div class="mt-16 flex flex-col gap-6">
    <div class="flex flex-col gap-2">
      <p
        class="font-display text-[clamp(1.6rem,3.4vw,2.6rem)] font-black tracking-[-0.04em] text-skala-text"
      >
        Servicios especiales
      </p>
      <p class="max-w-[60ch] text-sm leading-7 text-skala-muted">
        {specialServices.note}
        <span class="ml-1 font-semibold text-skala-accent">
          ({specialServices.travelNote})
        </span>
      </p>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
      {
        specialServices.items.map((service, index) => {
          const icons = [FiHeart, FiCamera, FiBriefcase, FiVideo];
          const Icon = icons[index % icons.length];
          return (
            <article
              class="flex flex-col gap-3 rounded-[26px] border border-skala-border bg-white/[0.035] p-6 transition duration-300 hover:-translate-y-1 hover:border-skala-accent/40"
              data-reveal
              style={`--reveal-delay: ${index * 80}ms;`}
            >
              <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-skala-accent/15 text-skala-accent">
                <Icon className="h-5 w-5" aria-hidden="true" />
              </span>
              <h3 class="m-0 font-display text-lg font-black tracking-[-0.03em] text-skala-text">
                {service.title}
              </h3>
              <p class="m-0 text-sm leading-7 text-skala-muted">
                {service.description}
              </p>
            </article>
          );
        })
      }
    </div>

    <a
      href={CONTACT_DATA.WHATSAPP_LINK(
        "Hola, quiero cotizar un servicio especial (evento/fotografía corporativa).",
      )}
      target="_blank"
      rel="noopener noreferrer"
      class="group mt-2 inline-flex w-fit items-center justify-center gap-3 rounded-full bg-skala-accent px-7 py-4 font-display text-[0.74rem] font-black uppercase tracking-[0.16em] text-skala-text-secondary shadow-[0_14px_36px_rgba(92,216,252,0.28)] transition duration-200 hover:-translate-y-0.5 hover:bg-skala-accent/90 focus-visible:ring-2 focus-visible:ring-skala-accent/60"
    >
      <span>Cotizar servicio especial</span>
      <FiArrowUpRight
        aria-hidden="true"
        className="transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
      />
    </a>
  </div>
</section>
