<script>
  const revealItems = document.querySelectorAll("[data-reveal]");

  if (revealItems.length) {
    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    if (reduceMotion) {
      revealItems.forEach((item) =>
        item.classList.add("is-visible", "reveal-complete"),
      );
    } else {
      const observer = new IntersectionObserver(
        (entries, currentObserver) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;

            const revealItem = entry.target as HTMLElement;

            if (!revealItem.classList.contains("is-visible")) {
              requestAnimationFrame(() => {
                revealItem.classList.add("is-visible");
              });

              revealItem.addEventListener(
                "transitionend",
                () => revealItem.classList.add("reveal-complete"),
                { once: true },
              );
              currentObserver.unobserve(revealItem);
            }
          });
        },
        {
          threshold: 0.15,
          rootMargin: "0px 0px -8% 0px",
        },
      );

      revealItems.forEach((item) => observer.observe(item));
    }
  }
</script>
