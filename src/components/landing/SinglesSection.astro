---
import { FiArrowUpRight } from "react-icons/fi";
import { CONTACT_DATA } from "../../data/contact_data";
import { singleServices } from "../../data/skala";
---

<section
  class="relative mx-auto flex w-full max-w-360 flex-col gap-8 px-5 md:px-12"
>
  <div
    class="grid gap-6 lg:grid-cols-[minmax(0,0.9fr)_minmax(320px,0.72fr)] lg:items-end"
  >
    <div>
      <h2
        class="m-0 max-w-[14ch] font-display text-[clamp(2.2rem,4.4vw,4.8rem)] leading-[0.96] tracking-[-0.06em]"
        data-reveal
      >
        Servicios sueltos para mover una idea puntual.
      </h2>
      <p
        class="mt-5 max-w-[56ch] text-[1.05rem] leading-8 text-skala-muted"
        data-reveal
        style="--reveal-delay: 120ms;"
      >
        Contrata piezas individuales sin compromiso mensual. Ideal para
        campañas, urgencias o una entrega puntual bien resuelta.
      </p>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
    {
      singleServices.map((service, index) => (
        <article
          class="group relative overflow-hidden rounded-[28px] border border-skala-border bg-[linear-gradient(180deg,rgba(8,24,52,0.72),rgba(4,20,46,0.86))] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.05)] transition duration-300 hover:-translate-y-1 hover:border-skala-accent/35 hover:bg-skala-accent/5"
          data-reveal
          style={`--reveal-delay: ${index * 55}ms;`}
        >
          <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_20%_0%,rgba(92,216,252,0.12),transparent_36%)] opacity-0 transition-opacity duration-300 group-hover:opacity-100" />

          <div class="relative flex items-start justify-between gap-4">
            <div class="flex h-11 w-11 items-center justify-center rounded-2xl border border-skala-accent/24 bg-skala-accent/8 text-skala-accent shadow-[inset_0_1px_0_rgba(255,255,255,0.06)] transition-transform duration-300 group-hover:scale-110">
              <service.icon className="h-5 w-5" aria-hidden="true" />
            </div>

            <span class="font-display text-[0.68rem] font-black uppercase tracking-[0.18em] text-white/30">
              {String(index + 1).padStart(2, "0")}
            </span>
          </div>

          <div class="relative mt-8">
            <h3 class="font-display text-[1.05rem] leading-tight tracking-[-0.04em] text-skala-text">
              {service.label}
            </h3>
            <p class="mt-3 text-sm leading-7 text-skala-muted">
              Servicio individual con alcance claro y entrega lista para usar.
            </p>
          </div>

          <a
            href={CONTACT_DATA.WHATSAPP_LINK(service.cta_message)}
            target="_blank"
            rel="noopener noreferrer"
            title="Contactar por este servicio"
            aria-label="Contactar por este servicio"
            class="group/cotizar relative mt-6 flex items-center justify-between overflow-hidden rounded-2xl border border-skala-accent/20 bg-skala-accent/8 px-4 py-3 text-skala-text hover:text-skala-text-secondary! transition duration-300 hover:-translate-y-0.5 hover:border-skala-accent/45 hover:bg-skala-accent hover:shadow-[0_18px_36px_rgba(92,216,252,0.2)] active:translate-y-0"
          >
            <span class="relative z-10 text-[0.66rem] font-black uppercase tracking-[0.16em]">
              Cotizar
            </span>
            <FiArrowUpRight
              aria-hidden="true"
              className="relative z-10 h-4 w-4 transition-transform duration-300 group-hover/cotizar:translate-x-0.5 group-hover/cotizar:-translate-y-0.5"
            />
          </a>
        </article>
      ))
    }
  </div>
</section>
