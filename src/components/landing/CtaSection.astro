---
import { FiArrowUpRight } from "react-icons/fi";
import { ctaLinks } from "../../data/cta";
---

<section
  class="mx-auto mt-5 grid w-full max-w-3360 gap-12 bg-[linear-gradient(135deg,rgba(92,216,252,0.96),rgba(30,163,232,0.92))] px-5 py-12 text-[#04142e] shadow-[0_28px_90px_rgba(30,163,232,0.22)] md:px-12 xl:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)] xl:items-center"
>
  <div data-reveal>
    <h2
      class="m-0 font-display text-[clamp(2.8rem,5.8vw,5.5rem)] leading-[0.95] tracking-[-0.07em]"
    >
      ¿Listo para Skalar?
      <em
        class="mt-3 block font-sans text-[0.7em] font-normal italic text-[#04142e]/58"
        >Hablemos.</em
      >
    </h2>
  </div>

  <div class="flex flex-col gap-6">
    <p
      class="max-w-[54ch] leading-8 text-[#04142e]/74"
      data-reveal
      style="--reveal-delay: 120ms;"
    >
      Háblanos de tu proyecto y te compartimos una primera dirección creativa
      para tu marca. <strong>En menos de 24 horas</strong> te respondemos con una
      propuesta inicial sin costo.
    </p>

    <div
      class="flex flex-wrap gap-3"
      data-reveal
      style="--reveal-delay: 180ms;"
    >
      {
        ctaLinks
          .map((action) => (
            <a
              href={action.href}
              target="_blank"
              rel="noopener noreferrer"
              title={action.label}
              aria-label={action.label}
              class="group inline-flex items-center justify-center gap-3 rounded-full border px-6 py-4 font-display text-[0.74rem] uppercase tracking-[0.16em] transition duration-200 hover:-translate-y-0.5 hover:scale-[1.01] focus-visible:ring-2 focus-visible:ring-[#04142e]/40 active:translate-y-px"
              class:list={[
                action.variant === "solid"
                  ? "border-[#04142e]/15 bg-[#04142e] text-white!"
                  : "border-[#04142e]/15 bg-transparent text-white hover:bg-[#04142e]/5",
              ]}
            >
              <action.icon
                className="h-5 w-5 shrink-0 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                aria-hidden="true"
              />
              <span>{action.label}</span>
              {action.variant === "outline" ? (
                <FiArrowUpRight
                  aria-hidden="true"
                  className="transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                />
              ) : null}
            </a>
          ))
          .filter((_, index) => index < 2)
      }
    </div>
  </div>
</section>
