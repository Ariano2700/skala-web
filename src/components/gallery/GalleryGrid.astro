---
import type { Gallery } from "../../sanity/gallery/gallery-mapper";
import { FiLock, FiImage, FiVideo } from "react-icons/fi";

interface Props {
  galleries: Gallery[];
}

const { galleries = [] } = Astro.props;

// Conteo de fotos/videos por galería para mostrar en la tarjeta.
const countMedia = (gallery: Gallery) => {
  const images = gallery.gallery.filter((m) => m.kind === "image").length;
  const videos = gallery.gallery.filter((m) => m.kind === "video").length;
  return { images, videos };
};

// Portada: usa coverImage si existe, si no la primera imagen de la galería.
const getCover = (gallery: Gallery): string => {
  if (gallery.coverImage?.url) return gallery.coverImage.url;
  const firstImage = gallery.gallery.find((m) => m.kind === "image");
  return firstImage?.url ?? "";
};
---

<section
  id="galerias"
  class="relative z-10 mx-auto w-full max-w-360 px-5 pb-28 pt-12 md:px-12"
  aria-labelledby="galerias-title"
>
  <div class="mb-8 flex items-end justify-between gap-4">
    <div>
      <h2
        id="galerias-title"
        class="m-0 font-display text-3xl font-black tracking-[-0.04em] text-skala-text md:text-4xl"
      >
        Galerías del evento
      </h2>
      <p class="mt-2 text-sm text-skala-muted">
        Haz clic en una tarjeta para ver y descargar las fotos y videos.
      </p>
    </div>
    <span
      class="hidden shrink-0 text-xs font-medium uppercase tracking-[0.16em] text-skala-muted sm:block"
    >
      {galleries.length} galerías
    </span>
  </div>

  {
    galleries.length === 0 ? (
      <div class="rounded-3xl border border-skala-border bg-white/[0.035] p-12 text-center">
        <p class="mb-3 font-display text-4xl font-black tracking-[-0.04em] text-skala-text">
          📸
        </p>
        <h3 class="mb-3 font-display text-2xl font-black tracking-[-0.04em] text-skala-text">
          Pronto subiremos las galerías.
        </h3>
        <p class="m-0 text-sm leading-7 text-skala-muted">
          Las fotos y videos del desfile se publicarán aquí después del evento.
        </p>
      </div>
    ) : (
      <>
        <div
          data-gallery-empty
          class="hidden rounded-3xl border border-skala-border bg-white/[0.035] p-12 text-center"
        >
          <p class="mb-3 font-display text-4xl font-black tracking-[-0.04em] text-skala-text">
            🔍
          </p>
          <h3 class="mb-3 font-display text-2xl font-black tracking-[-0.04em] text-skala-text">
            No encontramos galerías con ese nombre.
          </h3>
          <p class="m-0 text-sm leading-7 text-skala-muted">
            Prueba con otro término o limpia el buscador.
          </p>
        </div>

        <div class="grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-4">
        {galleries.map((gallery) => {
          const cover = getCover(gallery);
          const { images, videos } = countMedia(gallery);
          const hasCode = Boolean(gallery.accessCode);
          return (
            <a
              href={`/galeria-desfile-canino/${gallery.slug}`}
              title={`Ver galería de ${gallery.name}`}
              aria-label={`Ver galería de ${gallery.name}`}
              class="group relative block overflow-hidden rounded-3xl border border-skala-border bg-[#181816] shadow-[0_24px_70px_rgba(0,0,0,0.22)] transition duration-300 hover:-translate-y-1 hover:border-skala-accent/40 focus-visible:ring-2 focus-visible:ring-skala-accent/60"
              data-reveal
              data-gallery-name={gallery.name.toLowerCase()}
            >
              <div class="relative aspect-square overflow-hidden bg-skala-surface">
                {cover ? (
                  <img
                    src={cover}
                    alt={gallery.coverImage?.alt || gallery.name}
                    loading="lazy"
                    class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105"
                  />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center bg-skala-surface text-skala-muted">
                    <FiImage className="h-10 w-10" />
                  </div>
                )}

                <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(8,8,8,0.08)_0%,rgba(8,8,8,0.36)_46%,rgba(8,8,8,0.86)_100%)] opacity-90 transition-opacity duration-300" />

                {hasCode && (
                  <span class="absolute right-3 top-3 inline-flex items-center gap-1.5 rounded-full border border-white/15 bg-black/50 px-2.5 py-1 text-[0.6rem] font-black uppercase tracking-[0.14em] text-white backdrop-blur">
                    <FiLock className="h-3 w-3" />
                    Privada
                  </span>
                )}

                <div class="absolute inset-x-0 bottom-0 p-4">
                  <p class="m-0 font-display text-lg font-black leading-tight tracking-[-0.03em] text-white">
                    {gallery.name}
                  </p>
                  <p class="mt-1 flex items-center gap-2 text-[0.68rem] font-bold uppercase tracking-[0.12em] text-skala-muted">
                    {images > 0 && <span>{images} fotos</span>}
                    {images > 0 && videos > 0 && <span>·</span>}
                    {videos > 0 && (
                      <span class="inline-flex items-center gap-1">
                        <FiVideo className="h-3 w-3" />
                        {videos}
                      </span>
                    )}
                  </p>
                </div>
              </div>
            </a>
          );
        })}
      </div>
      </>
    )
  }
</section>

<script>
  const search = document.getElementById("gallery-search") as HTMLInputElement | null;
  const clearBtn = document.getElementById("gallery-search-clear");
  const grid = document.getElementById("galerias");
  if (search && grid) {
    const cards = Array.from(
      grid.querySelectorAll<HTMLElement>("[data-gallery-name]"),
    );
    const emptyState = grid.querySelector<HTMLElement>("[data-gallery-empty]");

    const apply = () => {
      const term = search.value.trim().toLowerCase();
      clearBtn?.classList.toggle("hidden", term.length === 0);
      let visible = 0;
      cards.forEach((card) => {
        const match = card.dataset.galleryName?.includes(term) ?? false;
        card.hidden = !match;
        if (match) visible += 1;
      });
      // Estado vacío de búsqueda (si no hay coincidencias).
      if (emptyState) {
        emptyState.classList.toggle("hidden", visible !== 0 || term.length === 0);
      }
    };

    search.addEventListener("input", apply);
    clearBtn?.addEventListener("click", () => {
      search.value = "";
      apply();
      search.focus();
    });
  }
</script>
