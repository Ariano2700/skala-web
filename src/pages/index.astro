---
import Layout from "../layouts/Layout.astro";
import AboutSection from "../components/landing/AboutSection.astro";
import AmbientBackdrop from "../components/landing/AmbientBackdrop.astro";
import CtaSection from "../components/landing/CtaSection.astro";
import HeroSection from "../components/landing/HeroSection.astro";
import MarqueeStrip from "../components/landing/MarqueeStrip.astro";
import PlansSection from "../components/landing/PlansSection.astro";
import ProcessSection from "../components/landing/ProcessSection.astro";
import RevealScript from "../components/landing/RevealScript.astro";
import ServicesSection from "../components/landing/ServicesSection.astro";
import SiteFooter from "../components/shared/SiteFooter.astro";
import SiteNav from "../components/shared/SiteNav.astro";
import SinglesSection from "../components/landing/SinglesSection.astro";
const pageTitle = "Skala - Agencia de Branding & Producción Audiovisual";
const pageDescription =
  "Agencia estratégica en Trujillo, Perú. Especialistas en diseño de marca, fotografía comercial, producción de video para redes sociales y campañas integrales.";
const canonicalUrl = (Astro.site ?? new URL("https://skalaagencia.netlify.app")).href;
const homeKeywords =
  "agencia de publicidad trujillo, productora audiovisual peru, diseño de marca, marketing digital trujillo, produccion de video, creacion de contenido, escala agencia, skala";
const homeStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    name: "Skala",
    url: canonicalUrl,
    image: `${canonicalUrl}logotype.jpg`,
    telephone: "+51947168626",
    areaServed: "Trujillo, Peru",
    priceRange: "$$",
    address: {
      "@type": "PostalAddress",
      addressLocality: "Trujillo",
      addressRegion: "La Libertad",
      addressCountry: "PE",
    },
    openingHoursSpecification: [
      {
        "@type": "OpeningHoursSpecification",
        dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        opens: "09:00",
        closes: "18:00",
      },
      {
        "@type": "OpeningHoursSpecification",
        dayOfWeek: ["Saturday"],
        opens: "09:00",
        closes: "13:00",
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Skala Agencia",
    url: canonicalUrl,
  },
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={canonicalUrl}
  structuredData={homeStructuredData}
  keywords={homeKeywords}
  robots="index, follow"
>
  <AmbientBackdrop />
  <SiteNav />
  <main class="relative z-10">
    <HeroSection />
    <MarqueeStrip />
    <AboutSection />
    <ServicesSection />
    <PlansSection />
    <SinglesSection />
    <ProcessSection />
    <CtaSection />
  </main>
  <SiteFooter />
  <RevealScript />
</Layout>
