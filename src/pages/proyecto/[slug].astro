---
import Layout from "../../layouts/Layout.astro";
import AmbientBackdrop from "../../components/landing/AmbientBackdrop.astro";
import SiteNav from "../../components/shared/SiteNav.astro";
import SiteFooter from "../../components/shared/SiteFooter.astro";
import SectionLabel from "../../components/landing/SectionLabel.astro";
import { portfolioProjects, getPortfolioAccentClass, type PortfolioProjectItem } from "../../components/portfolio/portfolio-data";
import { FiArrowLeft, FiExternalLink } from "react-icons/fi";

export async function getStaticPaths() {
  return portfolioProjects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

interface Props {
  project: PortfolioProjectItem;
}

const { project } = Astro.props;

const pageTitle = `${project.title} - Skala Portafolio`;
const pageDescription = project.details?.description || `Proyecto de ${project.categoryLabel} para ${project.client}`;
const canonicalUrl = new URL(
  `/proyecto/${project.id}/`,
  Astro.site ?? new URL("https://skalaagencia.netlify.app")
).href;
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={canonicalUrl}
  robots="index, follow"
>
  <AmbientBackdrop />
  <SiteNav />
  <main class="relative z-10">
    <section class="relative mx-auto w-full max-w-360 px-5 py-12 md:px-12 lg:py-20">
      <a
        href="/portafolio"
        class="mb-8 inline-flex items-center gap-2 text-sm font-medium text-skala-muted transition-colors hover:text-skala-accent"
        aria-label="Volver al portafolio"
      >
        <FiArrowLeft className="h-4 w-4" />
        Volver al portafolio
      </a>

      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
        <div class="relative">
          <div
            class="aspect-16/10 w-full rounded-4xl border border-skala-border shadow-[0_30px_80px_rgba(0,0,0,0.42)]"
            style={`background: ${project.visual.gradient};`}
          >
            <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(8,8,8,0.08)_0%,rgba(8,8,8,0.36)_46%,rgba(8,8,8,0.86)_100%)] opacity-90" />
            <div class="portfolio-shine absolute -inset-x-8 -top-2 h-16 w-20 -rotate-45 bg-linear-to-r from-transparent via-white/10 to-transparent opacity-0 transition-opacity duration-500" />
            <div class="absolute inset-x-0 bottom-0 p-8">
              <span class={`mb-4 inline-flex h-2 w-10 rounded-full ${getPortfolioAccentClass(project)}`}></span>
              <p class="m-0 text-[0.68rem] font-black uppercase tracking-[0.22em] text-skala-accent">
                {project.categoryLabel}
              </p>
              <h1 class="mt-3 font-display text-4xl font-black leading-tight tracking-[-0.04em] text-skala-text md:text-5xl">
                {project.title}
              </h1>
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-8">
          <div>
            <SectionLabel label="Cliente" />
            <p class="mt-2 text-xl font-medium text-skala-text">{project.client}</p>
          </div>

          {project.details && (
            <>
              <div>
                <SectionLabel label="Descripción" />
                <p class="mt-2 text-base leading-7 text-skala-muted">{project.details.description}</p>
              </div>

              <div>
                <SectionLabel label="Desafío" />
                <p class="mt-2 text-base leading-7 text-skala-muted">{project.details.challenge}</p>
              </div>

              <div>
                <SectionLabel label="Solución" />
                <p class="mt-2 text-base leading-7 text-skala-muted">{project.details.solution}</p>
              </div>

              <div>
                <SectionLabel label="Resultados" />
                <ul class="mt-3 flex flex-col gap-2">
                  {project.details.results.map((result) => (
                    <li class="flex items-start gap-2 text-sm text-skala-muted">
                      <span class={`mt-1.5 h-1.5 w-1.5 rounded-full ${getPortfolioAccentClass(project)}`}></span>
                      <span>{result}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <div class="flex items-center gap-4">
                <div>
                  <SectionLabel label="Herramientas" />
                  <p class="mt-1 text-sm text-skala-muted">{project.details.tools.join(", ")}</p>
                </div>
                <div class="h-px flex-1 bg-skala-border"></div>
                <div>
                  <SectionLabel label="Duración" />
                  <p class="mt-1 text-sm text-skala-muted">{project.details.duration}</p>
                </div>
              </div>
            </>
          )}
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</Layout>

<style>
  .portfolio-shine {
    pointer-events: none;
  }
</style>