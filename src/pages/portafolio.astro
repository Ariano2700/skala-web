---
import Layout from "../layouts/Layout.astro";
import AmbientBackdrop from "../components/landing/AmbientBackdrop.astro";
import RevealScript from "../components/landing/RevealScript.astro";
import SiteFooter from "../components/shared/SiteFooter.astro";
import SiteNav from "../components/shared/SiteNav.astro";
import PortfolioCta from "../components/portfolio/PortfolioCta.astro";
import PortfolioFilters from "../components/portfolio/PortfolioFilters.astro";
import PortfolioGrid from "../components/portfolio/PortfolioGrid.astro";
import PortfolioHero from "../components/portfolio/PortfolioHero.astro";
import { portfolioProjects } from "../components/portfolio/portfolio-data";

const pageTitle =
  "Portafolio Skala - Agencia & Productora Audiovisual en Trujillo";
const pageDescription =
  "Explora el portafolio de Skala en Trujillo: casos de éxito en branding, fotografía publicitaria, producción audiovisual y social media estratégico.";
const canonicalUrl = new URL(
  "/portafolio/",
  Astro.site ?? new URL("https://skalaagencia.netlify.app"),
).href;
const portfolioKeywords =
  "portafolio audiovisual, casos de exito marketing, proyectos de branding, fotografia publicitaria trujillo, produccion de reels, diseño grafico trujillo, skala portafolio";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService", // El idóneo para una Agencia con sede física
    name: "Skala",
    url: canonicalUrl,
    image: new URL("/logotype.jpg", Astro.site ?? "https://skalaagencia.netlify.app")
      .href,
    address: {
      "@type": "PostalAddress",
      addressLocality: "Trujillo",
      addressRegion: "La Libertad",
      addressCountry: "PE",
    },
    openingHoursSpecification: [
      {
        "@type": "OpeningHoursSpecification",
        dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        opens: "09:00",
        closes: "18:00",
      },
      {
        "@type": "OpeningHoursSpecification",
        dayOfWeek: ["Saturday"],
        opens: "09:00",
        closes: "13:00",
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "@id": `${canonicalUrl}#portfolio-list`,
    name: "Casos de Éxito de Skala",
    description: "Lista de proyectos desarrollados por la agencia Skala",
    numberOfItems: portfolioProjects?.length || 0,
    itemListElement: (portfolioProjects || []).map(
      (project: any, index: number) => ({
        "@type": "ListItem",
        position: index + 1,
        url: `${canonicalUrl}#${project.id}`,
        name: project.title,
        description: `${project.categoryLabel} realizado para ${project.client}.`,
      }),
    ),
  },
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={canonicalUrl}
  structuredData={structuredData}
  keywords={portfolioKeywords}
  robots="index, follow"
>
  <AmbientBackdrop />
  <SiteNav />
  <main id="top" class="relative z-10">
    <PortfolioHero />
    <PortfolioFilters />
    <PortfolioGrid />
    <PortfolioCta />
  </main>
  <SiteFooter />
  <RevealScript />
</Layout>
