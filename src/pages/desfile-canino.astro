    }
  </style>

  <script>
    // Número de WhatsApp para el pre-registro (mismo que CONTACT_DATA).
    const REGISTRO_WA = "51959739831";

    function initCountdown() {
      const root = document.getElementById("countdown");
      if (!root) return;
      const target = new Date(root.dataset.eventDate as string).getTime();
      const daysEl = root.querySelector(
        ".countdown-days",
      ) as HTMLElement | null;
      const hoursEl = root.querySelector(
        ".countdown-hours",
      ) as HTMLElement | null;
      const minutesEl = root.querySelector(
        ".countdown-minutes",
      ) as HTMLElement | null;
      const secondsEl = root.querySelector(
        ".countdown-seconds",
      ) as HTMLElement | null;

      const pad = (n: number) => String(n).padStart(2, "0");

      function tick() {
        const diff = target - Date.now();
        if (diff <= 0) {
          if (daysEl) daysEl.textContent = "0";
          if (hoursEl) hoursEl.textContent = "00";
          if (minutesEl) minutesEl.textContent = "00";
          if (secondsEl) secondsEl.textContent = "00";
          return;
        }
        const days = Math.floor(diff / 86400000);
        const hours = Math.floor((diff % 86400000) / 3600000);
        const minutes = Math.floor((diff % 3600000) / 60000);
        const seconds = Math.floor((diff % 60000) / 1000);
        if (daysEl) daysEl.textContent = String(days);
        if (hoursEl) hoursEl.textContent = pad(hours);
        if (minutesEl) minutesEl.textContent = pad(minutes);
        if (secondsEl) secondsEl.textContent = pad(seconds);
      }

      tick();
      window.setInterval(tick, 1000);
    }

    // Pre-registro: construye un mensaje de WhatsApp con los datos del lead.
    function initRegistroForm() {
      const form = document.getElementById("registro-form") as HTMLFormElement | null;
      if (!form) return;
      form.addEventListener("submit", (e) => {
        e.preventDefault();
        const data = new FormData(form);
        const nombre = String(data.get("nombre") || "").trim();
        const mascota = String(data.get("mascota") || "").trim();
        const tipo = String(data.get("tipo") || "").trim();
        const msg =
          "Hola, quiero pre-registrar a mi mascota al Desfile Patriótico Canino 🐾\n" +
          `• Mi nombre: ${nombre}\n` +
          `• Mascota: ${mascota}\n` +
          `• Tipo: ${tipo}`;
        const link = `https://wa.me/${REGISTRO_WA}?text=${encodeURIComponent(msg)}`;
        window.open(link, "_blank", "noopener");
        form.reset();
      });
    }

    initCountdown();
    initRegistroForm();
    document.addEventListener("astro:page-load", () => {
      initCountdown();
      initRegistroForm();
    });
  </script>
