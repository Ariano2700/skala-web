---
import LenisScroll from "../components/shared/LenisScroll";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  structuredData?: any;
  keywords?: string;
  robots?: string;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogImage = "/logotype.jpg",
  structuredData,
  keywords,
  robots,
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://skala.netlify.app");
const absoluteOgImage = new URL(ogImage, siteUrl).href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta name="keywords" content={keywords} />
    <meta name="robots" content={robots || "index, follow"} />
    <meta name="author" content="Skala Agencia" />
    <meta name="publisher" content="Skala" />
    <meta name="geo.region" content="PE-LL" />
    <meta name="geo.placename" content="Trujillo" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:site_name" content="Skala" />
    <meta property="og:locale" content="es_PE" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />
    <meta name="twitter:creator" content="@skalaagencia" />

    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Skala" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin="anonymous"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Unbounded:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    {
      structuredData && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(structuredData)}
        />
      )
    }
  </head>
  <body
    class="min-h-screen bg-[#04142e] text-[#f4f8ff] scroll-smooth antialiased"
  >
    <LenisScroll client:load />
    <slot />
  </body>
</html>
